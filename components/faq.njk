<style>
    .faq-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .faq-content.open {
      max-height: 1000px;
    }
    
    .faq-inner {
      opacity: 0;
      transform: translateY(-10px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    
    .faq-content.open .faq-inner {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.1s;
    }
    
    .chevron {
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .chevron.rotate {
      transform: rotate(180deg);
    }
    
    .bg-theme-area-dark {
      background-color: #1a1a1a;
    }
    
    .text-text-secondary {
      color: #a0a0a0;
    }
    
    .faq-button {
      cursor: pointer;
    }
    
    /* Changed from .rounded-xl to a more specific selector */
    .faq-section .rounded-xl {
      transition: all 0.3s ease;
    }
    
    .faq-section {
      margin-bottom: 80px;
    }

/* FAQ Mobile Support */

/* Base styles are already mobile-friendly, but let's enhance them */
.faq-section {
    margin-bottom: 80px;
    padding: 0 1rem;
}

@media (max-width: 1024px) {
    .faq-section {
        max-width: 100%;
        padding: 0 1.5rem;
        margin-bottom: 100px; /* Account for mobile nav */
    }
}

@media (max-width: 768px) {
    .faq-section {
        padding: 0 1rem;
        margin-bottom: 100px;
    }

    /* Reduce spacing between FAQ items */
    .faq-section .space-y-4 > * + * {
        margin-top: 0.75rem;
    }

    /* Adjust FAQ card padding */
    .faq-button {
        padding: 1rem;
    }

    /* Adjust heading size */
    .faq-button h3 {
        font-size: 1rem;
        line-height: 1.5;
        padding-right: 1rem;
    }

    /* Adjust chevron size */
    .chevron {
        width: 1.25rem;
        height: 1.25rem;
    }

    /* Adjust content padding */
    .faq-inner {
        padding: 0 1rem 1rem;
        font-size: 0.9375rem;
        line-height: 1.6;
    }

    /* Adjust max-height for smoother animations on mobile */
    .faq-content.open {
        max-height: 800px;
    }
}

@media (max-width: 640px) {
    .faq-section {
        padding: 0 0.75rem;
        margin-bottom: 90px;
    }

    /* Further reduce spacing */
    .faq-section .space-y-4 > * + * {
        margin-top: 0.625rem;
    }

    /* Smaller padding for compact mobile screens */
    .faq-button {
        padding: 0.875rem;
    }

    /* Smaller heading */
    .faq-button h3 {
        font-size: 0.9375rem;
        line-height: 1.4;
        padding-right: 0.75rem;
    }

    /* Smaller chevron */
    .chevron {
        width: 1.125rem;
        height: 1.125rem;
    }

    /* Adjust inner content */
    .faq-inner {
        padding: 0 0.875rem 0.875rem;
        font-size: 0.875rem;
        line-height: 1.5;
    }

    /* Reduce border radius slightly */
    .faq-section .rounded-xl {
        border-radius: 0.75rem;
    }
}

@media (max-width: 480px) {
    .faq-section {
        padding: 0 0.5rem;
        margin-bottom: 85px;
    }

    /* Minimal spacing for very small screens */
    .faq-section .space-y-4 > * + * {
        margin-top: 0.5rem;
    }

    /* Compact button */
    .faq-button {
        padding: 0.75rem;
    }

    /* Compact heading */
    .faq-button h3 {
        font-size: 0.875rem;
        line-height: 1.3;
        padding-right: 0.5rem;
    }

    /* Smaller chevron for tiny screens */
    .chevron {
        width: 1rem;
        height: 1rem;
    }

    /* Compact content */
    .faq-inner {
        padding: 0 0.75rem 0.75rem;
        font-size: 0.8125rem;
        line-height: 1.5;
    }

    /* Further reduce border radius */
    .faq-section .rounded-xl {
        border-radius: 0.625rem;
    }

    /* Reduce max height for smoother animation */
    .faq-content.open {
        max-height: 600px;
    }
}

/* Landscape mode adjustments */
@media (max-width: 979px) and (max-height: 500px) {
    .faq-section {
        margin-bottom: 70px;
    }

    .faq-button {
        padding: 0.75rem 1rem;
    }

    .faq-button h3 {
        font-size: 0.9375rem;
    }

    .faq-inner {
        font-size: 0.875rem;
    }
}

/* Touch device optimizations */
@media (hover: none) and (pointer: coarse) {
    /* Increase touch targets */
    .faq-button {
        min-height: 3.5rem;
        padding: 1rem;
    }

    /* Remove hover effect on touch devices */
    .faq-section .rounded-xl:hover {
        border-color: rgba(255, 255, 255, 0.05);
    }

    /* Active state for touch feedback */
    .faq-button:active {
        background-color: rgba(255, 0, 255, 0.05);
    }
}

/* Prevent text selection on button clicks */
@media (max-width: 768px) {
    .faq-button {
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        -webkit-user-select: none;
    }

    /* Ensure smooth scrolling when FAQ opens */
    .faq-content {
        will-change: max-height;
    }
}

/* Safe area support for devices with notches */
@supports (padding: env(safe-area-inset-bottom)) {
    @media (max-width: 768px) {
        .faq-section {
            margin-bottom: calc(90px + env(safe-area-inset-bottom));
            padding-left: max(0.75rem, env(safe-area-inset-left));
            padding-right: max(0.75rem, env(safe-area-inset-right));
        }
    }
}
  </style>
</head>
<body>

<div class="faq-section max-w-3xl mx-auto space-y-4">
  <div class="rounded-xl border border-white/5 bg-theme-area-dark overflow-hidden hover:border-[#8e08ff]/30">
    <button class="faq-button w-full flex items-center justify-between p-6 text-left transition-colors">
      <h3 class="text-lg font-semibold text-white pr-8">What Windows versions do the product work on?</h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron w-5 h-5 text-[#ff00ff] flex-shrink-0">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </button>
    <div class="faq-content">
      <div class="faq-inner px-6 pb-6 text-text-secondary leading-relaxed">Our products are compatible with Windows 10 and Windows 11. For more later versions of windows we may not support it currently, please open a support ticket on Discord here or check the product description on our website for verification. We do not support consoles or any operating systems other than Windows.</div>
    </div>
  </div>

  <div class="rounded-xl border border-white/5 bg-theme-area-dark overflow-hidden hover:border-[#8e08ff]/30">
    <button class="faq-button w-full flex items-center justify-between p-6 text-left transition-colors">
      <h3 class="text-lg font-semibold text-white pr-8">Is the Software easy to setup?</h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron w-5 h-5 text-[#ff00ff] flex-shrink-0">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </button>
    <div class="faq-content">
      <div class="faq-inner px-6 pb-6 text-text-secondary leading-relaxed">Yes, our software comes with detailed step-by-step guides. If you need any assistance during the setup process, our customer support is available to assist you quickly and work around the clock.</div>
    </div>
  </div>

  <div class="rounded-xl border border-white/5 bg-theme-area-dark overflow-hidden hover:border-[#8e08ff]/30">
    <button class="faq-button w-full flex items-center justify-between p-6 text-left transition-colors">
      <h3 class="text-lg font-semibold text-white pr-8">What Payment methods do you accept?</h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron w-5 h-5 text-[#ff00ff] flex-shrink-0">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </button>
    <div class="faq-content">
      <div class="faq-inner px-6 pb-6 text-text-secondary leading-relaxed">We accept a variety of payment methods, including card, and cryptocurrencies for our online store and PayPal in our discord server (https://discord.gg/yzCy3EFJaS) to ensure your purchase is convenient and secure.</div>
    </div>
  </div>

  <div class="rounded-xl border border-white/5 bg-theme-area-dark overflow-hidden hover:border-[#8e08ff]/30">
    <button class="faq-button w-full flex items-center justify-between p-6 text-left transition-colors">
      <h3 class="text-lg font-semibold text-white pr-8">Do you offer refunds if the software doesn't work?</h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron w-5 h-5 text-[#ff00ff] flex-shrink-0">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </button>
    <div class="faq-content">
      <div class="faq-inner px-6 pb-6 text-text-secondary leading-relaxed">We offer refunds only in specific cases where the software is proven to be non-functional. However, we recommend contacting our support team first for troubleshooting, as most issues can be resolved quickly.</div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqButtons = document.querySelectorAll('.faq-button');
    
    faqButtons.forEach(button => {
      button.addEventListener('click', function() {
        const parent = this.closest('.rounded-xl');
        const content = parent.querySelector('.faq-content');
        const chevron = this.querySelector('.chevron');
        const isOpen = content.classList.contains('open');
        
        document.querySelectorAll('.faq-content').forEach(item => {
          item.classList.remove('open');
        });
        
        document.querySelectorAll('.chevron').forEach(icon => {
          icon.classList.remove('rotate');
        });
        
        if (!isOpen) {
          content.classList.add('open');
          chevron.classList.add('rotate');
        }
      });
    });
  });
</script>

</body>
</html>