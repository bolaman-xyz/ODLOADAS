<div class="product-wrapper component" data-component-id="{{ componentId }}">
  <div class="container-fluid" style="max-width: 1650px; margin: 0 auto;">
    <section class="py-5-nav">
      <div class="container-fluid px-4 px-lg-5 my-5" style="max-width: 1650px; margin: 0 auto;">

        <div class="row gx-4 gx-lg-5 mb-5">
          <div class="col-lg-12">
            <div class="product-main-container p-4">
              <div class="row gx-4 gx-lg-5">

                <div class="col-lg-6">
                  {% if product.image_urls|length > 0 %}
                  <div class="carousel slide carousel-fade mb-3" id="productImageCarousel" data-bs-ride="carousel">
                    <div class="carousel-inner">
                      {% for image in product.image_urls %}
                      <div class="carousel-item {{ 'active' if loop.first }}">
                        <img src="{{ image }}" class="d-block w-100" alt="{{ product.name }}" />
                      </div>
                      {% endfor %}
                    </div>

                    {% if product.image_urls|length > 1 %}
                    <button class="carousel-control-prev" type="button" data-bs-target="#productImageCarousel" data-bs-slide="prev">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"></path>
                      </svg>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#productImageCarousel" data-bs-slide="next">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"></path>
                      </svg>
                    </button>
                    {% endif %}

                    {% if product.image_urls|length > 1 %}
                    <div class="thumbnails">
                      {% for image in product.image_urls %}
                      <button
                        type="button"
                        data-bs-target="#productImageCarousel"
                        data-bs-slide-to="{{ loop.index0 }}"
                        class="thumbnail-btn {{ 'active' if loop.first }}"
                      >
                        <img src="{{ image }}" alt="Thumbnail {{ loop.index }}" />
                      </button>
                      {% endfor %}
                    </div>
                    {% endif %}
                  </div>
                  {% elif product.image_url %}
                  <img src="{{ product.image_url }}" class="card-img-top mb-3" alt="{{ product.name }}" />
                  {% else %}
                  <div class="card-img-top product-img-placeholder text-center mb-3 d-flex align-items-center justify-content-center" style="height: 400px; background: rgba(255,255,255,0.05); border-radius: 12px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 256 256" style="opacity: 0.3;">
                      <path fill="currentColor" d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27Z"/>
                    </svg>
                  </div>
                  {% endif %}
                </div>

                <div class="col-lg-6">
                  <div x-data="productForm">

                    <div class="d-flex justify-content-between align-items-start mb-3">
                      <h1 class="display-6 fw-bolder mb-0">{{ product.name }}</h1>
                      <div class="pricing-section">
                        <div class="price">
                          <h3 class="mb-0" x-text="appCurrency.format(totalPrice, '{{ product.currency }}')"></h3>
                        </div>
                      </div>
                    </div>

                    <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
{% if product.status_color or product.status_text %}
<div class="status-badge relative inline-flex items-center gap-2 px-3 py-2 rounded-md overflow-hidden" 
     style="color: {{ product.status_color }}; border-left: 2px solid {{ product.status_color }}; background: {{ product.status_color }}20;">
  <span class="flex-shrink-0 relative z-10 d-flex align-items-center justify-content-center" style="width: 20px; height: 20px;">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor" style="display: block;">
      <path d="M320 576C178.6 576 64 461.4 64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576zM320 112C205.1 112 112 205.1 112 320C112 434.9 205.1 528 320 528C434.9 528 528 434.9 528 320C528 205.1 434.9 112 320 112zM390.7 233.9C398.5 223.2 413.5 220.8 424.2 228.6C434.9 236.4 437.3 251.4 429.5 262.1L307.4 430.1C303.3 435.8 296.9 439.4 289.9 439.9C282.9 440.4 276 437.9 271.1 433L215.2 377.1C205.8 367.7 205.8 352.5 215.2 343.2C224.6 333.9 239.8 333.8 249.1 343.2L285.1 379.2L390.7 234z"></path>
