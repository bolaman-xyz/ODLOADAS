                      </div>
                      {% endif %}

                      <div x-show="buyNowError" x-cloak class="alert alert-warning mb-3" role="alert" x-text="buyNowError"></div>

                      <div class="d-flex flex-column flex-lg-row gap-3 buy-buttons">
                        {% if not properties.hide_add_to_cart %}
                        <div class="col">
                          <button
                            type="button"
                            x-on:click="addToCart"
                            class="w-100 btn btn-primary d-flex align-items-center justify-content-center gap-2"
                            :disabled="outOfStock || cartLimitReached || addingToCart"
                          >
                            <template x-if="!addingToCart && !addedToCart">
                              <span class="d-flex align-items-center justify-content-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
                                  <path d="M239.89,198.12l-14.26-120a16,16,0,0,0-16-14.12H176a48,48,0,0,0-96,0H46.33a16,16,0,0,0-16,14.12l-14.26,120A16,16,0,0,0,20,210.6a16.13,16.13,0,0,0,12,5.4H223.92A16.13,16.13,0,0,0,236,210.6,16,16,0,0,0,239.89,198.12ZM128,32a32,32,0,0,1,32,32H96A32,32,0,0,1,128,32Z"/>
                                </svg>
                                <span x-text="cartLimitReached ? 'Cart Limit' : 'Add to Cart'"></span>
                              </span>
                            </template>
                            <template x-if="addingToCart">
                              <span class="d-flex align-items-center justify-content-center gap-2">
                                <span>Adding...</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="animate-spin" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
                                  <path d="M232,128a104,104,0,0,1-208,0c0-41,23.81-78.36,60.66-95.27a8,8,0,0,1,6.68,14.54C60.15,61.59,40,93.27,40,128a88,88,0,0,0,176,0c0-34.73-20.15-66.41-51.34-80.73a8,8,0,0,1,6.68-14.54C208.19,49.64,232,87,232,128Z"/>
                                </svg>
                              </span>
                            </template>
                            <template x-if="addedToCart">
                              <span class="d-flex align-items-center justify-content-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
                                  <path d="M239.89,198.12l-14.26-120a16,16,0,0,0-16-14.12H176a48,48,0,0,0-96,0H46.33a16,16,0,0,0-16,14.12l-14.26,120A16,16,0,0,0,20,210.6a16.13,16.13,0,0,0,12,5.4H223.92A16.13,16.13,0,0,0,236,210.6,16,16,0,0,0,239.89,198.12ZM128,32a32,32,0,0,1,32,32H96A32,32,0,0,1,128,32Z"/>
                                </svg>
                                <span>View Cart</span>
                              </span>
                            </template>
                          </button>
                        </div>
                        {% endif %}
                        {% if not properties.hide_buy_now %}
                        <div class="col">
                          <button
                            type="submit"
                            class="w-100 btn btn-outline-primary d-flex align-items-center justify-content-center gap-2"
                            :disabled="outOfStock || buyingNow"
                          >
                            <span>Buy Now</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                              <path d="M9.575 12L5.7 8.1q-.275-.275-.288-.687T5.7 6.7q.275-.275.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.687.288T5.7 17.3q-.275-.275-.275-.7t.275-.7zm6.6 0L12.3 8.1q-.275-.275-.288-.687T12.3 6.7q.275-.275.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.687.288T12.3 17.3q-.275-.275-.275-.7t.275-.7z"></path>
                            </svg>
                          </button>
                        </div>
                        {% endif %}
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="row gx-4 gx-lg-5 mb-4">
          <div class="col-12">
            <div class="description-container p-4">
