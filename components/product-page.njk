{% if product.product_badges.page|length > 0 %}
<div style="display: flex; flex-wrap: wrap; gap: 8px;">
  {% for productBadge in product.product_badges.page %}
  <span style="position: relative; display: inline-flex; align-items: center; gap: 8px; padding: 8px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: white; line-height: 1; white-space: nowrap; overflow: hidden; background-color: {{ productBadge.color or '#8e08ff' }};">
    {% if productBadge.icon %}
    <span style="width: 20px; height: 20px; flex-shrink: 0; position: relative; z-index: 10; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #8e08ff 0%, #8e08ff 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
      <i class="{{ productBadge.icon }}" style="font-size: 1rem; line-height: 1;"></i>
    </span>
    {% endif %}
    <span style="position: relative; z-index: 10; line-height: 1;">{{ productBadge.label }}</span>
  </span>
  {% endfor %}
</div>
{% endif %}
                    </div>
                    {% if 'sales' in liveStats or 'views' in liveStats %}
                    <div class="live-stats mb-4">
                      {% if 'views' in liveStats %}
                      <div class="d-flex align-items-center gap-2 mb-2">
