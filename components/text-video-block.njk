<section class="py-20" id="products" data-component-id="{{ componentId }}">
<style>

.cypherxGroups {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5em;
    list-style: none;
    max-width: 1600px;
    margin: 0 auto;
    margin: -100px auto 2em auto;
    width: 100%;
    border: 1px solid rgb(var(--theme-area_background_light));
    align-items: center;
    justify-content: space-between;
    padding: 2em;
    background: rgba(31, 31, 31, 0.3);
    background-size: 20%;
    background-repeat: repeat;
    border-radius: var(--border--radius) !important;
}
        .cypherxGroup {
            flex: 0 0 270px;
            position: relative;
        }
@media (max-width: 768px) {
    .cypherxGroups {
        flex-direction: column;
        align-items: stretch;
        margin-top: 0;
        padding: 1rem;
                background: transparent;
        border: none;
        gap: 1rem;
    }
    
    .cypherxGroup {
        flex: 1 1 auto;
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
    }
    
    .cypherxGroup > a {
        min-height: 320px;
        max-height: 320px;
    }
    
    .cypherxGroup_footer {
        padding: 1.5em 1em;
    }
    
    .cypherxGroup_title {
        font-size: 1.3rem;
    }
    
    .priceFrom {
        font-size: 10px;
        padding: 0.3em 0.3em 0.25em 0.8em;
    }
    
    .priceFrom > .price {
        padding: 0.6em 0.8em;
        font-size: 12px;
    }
}

@keyframes glow1 {
    0%, 100% { opacity: 0.4; transform: scale(1) translate(0, 0); }
    50% { opacity: 0.8; transform: scale(1.1) translate(5px, -5px); }
}

@keyframes glow2 {
    0%, 100% { opacity: 0.3; transform: scale(1) translate(0, 0); }
    50% { opacity: 0.6; transform: scale(1.2) translate(-3px, 3px); }
}

@keyframes glow3 {
    0%, 100% { opacity: 0.3; transform: scale(1) translate(0, 0); }
    50% { opacity: 0.7; transform: scale(1.15) translate(8px, 0); }
}

@keyframes glow4 {
    0%, 100% { opacity: 0.2; transform: scale(1) translate(0, 0); }
    50% { opacity: 0.5; transform: scale(1.3) translate(-5px, 5px); }
}

@keyframes glow5 {
    0%, 100% { opacity: 0.3; transform: translateX(-50%) scale(1); }
    50% { opacity: 0.6; transform: translateX(-50%) scale(1.2) translate(0, -5px); }
}

@media (max-width: 480px) {
    .cypherxGroup:before,
    .cypherxGroup:after,
    .cypherxGroup .glow-3,
    .cypherxGroup .glow-4,
    .cypherxGroup .glow-5 {
        opacity: 0.5;
        transform: scale(0.8);
                background: transparent;
        border: none;
    }
    
    .cypherxGroup > a:before {
        animation: cardAnim 15s linear infinite, cardAnim__opacity 6s linear infinite;
    }
    
    .cypherxGroups {
        flex-direction: column;
        align-items: stretch;
        margin-top: 0;
    }
    
    .cypherxGroup {
        flex: 1 1 auto;
        width: 100%;
    }
}

@media (hover: none) and (pointer: coarse) {
    .cypherxGroup .cypherxGroup_title:not(.pf_none) {
        transform: translateY(20px);
    }
    
    .cypherxGroup .priceFrom {
        transform: translateY(35px);
    }
    
    /* Add active state for touch feedback */
    .cypherxGroup > a:active {
        transform: scale(0.98);
        transition: transform 0.1s ease;
    }
    
    /* Remove hover effects on touch devices */
    .cypherxGroup:hover .cypherxGroup_image > img {
        filter: grayscale(100%) brightness(0.7);
    }
    
    .cypherxGroup:hover .cypherxGroup_title {
        transform: translateY(41px);
        transform: scale(1);
    }
    
    .cypherxGroup:hover .priceFrom {
        transform: translateY(70px);
    }
}

@media (max-width: 360px) {
    .cypherxGroups {
        padding: 0.6rem;
        gap: 0.6rem;
                background: transparent;
        border: none;
        margin: 0 0.3rem;
        width: calc(100% - 0.6rem);
    }
    
    .cypherxGroup > a {
        min-height: 260px;
        max-height: 260px;
    }
    
    .cypherxGroup_title {
        font-size: 1.1rem;
    }
    
    .cypherxGroup_footer {
        padding: 1em 0.6em;
    }
    
    .priceFrom {
        font-size: 8px;
    }
    
    .priceFrom > .price {
        font-size: 10px;
        padding: 0.4em 0.5em;
    }
}

/* Accessibility - reduced motion */
@media (prefers-reduced-motion: reduce) {
    .cypherxGroup > a:before,
    .cypherxGroup:before,
    .cypherxGroup:after,
    .cypherxGroup .glow-3,
    .cypherxGroup .glow-4,
    .cypherxGroup .glow-5 {
        animation: none;
    }
    
    .cypherxGroup_title,
    .priceFrom,
    .cypherxGroup_image > img {
        transition: none;
    }
}
    .priceFrom > .price {
        padding: 0.5em 0.6em;
        font-size: 11px;
    }
        .cypherxGroup > a {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            border-radius: 20px;
            min-height: 480px;
            max-height: 480px;
            position: relative;
            text-decoration: none;
            background: url('https://i.postimg.cc/mZzv50PB/dwdadadadada.png');
            overflow: hidden;
        }

        .cypherxGroup > a:before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: inherit;
            padding: 1px;
            background: conic-gradient(from calc(var(--angle) + 187deg), transparent 0, rgb(var(--theme-brand_primary)) 20%,transparent 25%);
            -webkit-mask: linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
            mask: linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
            mask-composite: xor;
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            animation: cardAnim 12s linear infinite, cardAnim__opacity 4s linear infinite;
            z-index: 10;
        }

        /* Five glows around each card */
        .cypherxGroup:before,
        .cypherxGroup:after {
            content: "";
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            z-index: -1;
        }

        .cypherxGroup:before {
            width: 100px;
            height: 100px;
            background: radial-gradient(circle, rgba(0, 255, 255, 0.4), transparent 70%);
            top: -20px;
            left: -20px;
            animation: glow1 3s ease-in-out infinite alternate;
        }

        .cypherxGroup:after {
            width: 80px;
            height: 80px;
            background: radial-gradient(circle, rgba(255, 0, 255, 0.3), transparent 70%);
            bottom: -15px;
            right: -15px;
            animation: glow2 4s ease-in-out infinite alternate;
        }

        .cypherxGroup .glow-3,
        .cypherxGroup .glow-4,
        .cypherxGroup .glow-5 {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            z-index: -1;
        }

        .cypherxGroup .glow-3 {
            width: 60px;
            height: 60px;
            background: radial-gradient(circle, rgba(255, 255, 0, 0.3), transparent 70%);
            top: 50%;
            left: -30px;
            animation: glow3 5s ease-in-out infinite alternate;
        }

        .cypherxGroup .glow-4 {
            width: 90px;
            height: 90px;
            background: radial-gradient(circle, rgba(0, 255, 0, 0.2), transparent 70%);
            top: -25px;
            right: -25px;
            animation: glow4 3.5s ease-in-out infinite alternate;
        }

        .cypherxGroup .glow-5 {
            width: 70px;
            height: 70px;
            background: radial-gradient(circle, rgba(255, 128, 0, 0.3), transparent 70%);
            bottom: 30%;
            left: 50%;
            transform: translateX(-50%);
            animation: glow5 4.5s ease-in-out infinite alternate;
        }

        .cypherxGroup_image {
            position: absolute;
            display: flex;
            height: 100%;
            width: 100%;
            overflow: hidden;
            border-radius: inherit;
            transition: all 0.3s linear;
            align-items: center;
            justify-content: center;
        }

        .cypherxGroup_image > img {
            width: 100%;
            height: 100%;
            border-radius: 10px;
            position: absolute;
            object-fit: cover;
            filter: grayscale(100%) brightness(0.7);
            transition: filter 0.3s ease;
        }

        .cypherxGroup:hover .cypherxGroup_image > img {
            filter: grayscale(0%) brightness(1);
        }

.cypherxGroup {
  transition: box-shadow 0.3s ease, border-radius 0.3s ease;
}
        .cypherxGroup_image:before {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            background: transparent;
            box-shadow: inset 0 2px 1px 0 rgb(var(--theme-brand_primary), 0.2), inset 0 -2px 1px 0 rgb(var(--theme-brand_primary), 0.2), inset 0 24px 48px 0 rgb(var(--theme-brand_primary), 0.1);
            top: 0;
            left: 0;
            z-index: 100;
            border-radius: inherit;
        }

        .cypherxGroup_image:after {
            content: "";
            position: absolute;
            width: 100%;
            height: 200px;
            bottom: -8px;
            background: linear-gradient(to top, rgb(var(--theme-page_background)), transparent);
        }

        .cypherxGroup_footer {
            z-index: 10;
            padding: 2em;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow: hidden;
        }

        .cypherxGroup_title {
            text-align: center;
            margin: 0 0 .5em 0;
            line-height: 1;
            color: #fff;
            transition: all 0.4s ease 0s;
            font-size: 1.5rem;
            font-weight: 700;
        }

        .cypherxGroup .cypherxGroup_title:not(.pf_none) {
            transform: translateY(41px);
        }

        .cypherxGroup:hover .cypherxGroup_title {
            transform: translateY(0);
            transform: scale(1.1);
        }

        .priceFrom {
            text-transform: uppercase;
            font-weight: 600;
            font-size: 11px;
            letter-spacing: 1px;
            color: #999999;
            background: rgb(var(--theme-area_background));
            border: 1px solid rgb(var(--theme-area_background_light));
            padding: .25em .25em .20em 1em;
            border-radius: 100vw;
            line-height: 1;
            display: flex;
            align-items: center;
            gap: .5em;
            box-shadow: 0 0 20px rgb(0, 0, 0, 0.10);
            transition: all 0.4s ease 0s;
        }

        .cypherxGroup .priceFrom {
            transform: translateY(70px);
        }

        .cypherxGroup:hover .priceFrom {
            transform: translateY(0);
        }

        .priceFrom > .price {
            background: rgb(0, 128, 0, .2);
            color: rgb(0, 128, 0);
            padding: .75em 1em;
            border-radius: 100px;
            font-size: 13px;
            display: inline-flex;
            align-items: center;
            line-height: 1;
        }

        @property --angle {
            syntax: "<angle>";
            inherits: false;
            initial-value: 0deg
        }

        @keyframes cardAnim {
            to {
                --angle: 360deg;
            }
        }

        @keyframes cardAnim__opacity {
            0% {
                opacity: 0.5;
            }

            20%,70% {
                opacity: 1;
            }

            to {
                opacity: 0.5;
            }
        }
    </style>
</head>
<body>
  <div class="ipsLayout_container">
  
    <div class="scale-up cypherxGroups">
        <!-- THE BO6 SECTION -->
        <div class="cypherxGroup">
            <a href="/black-ops-6">
                <div class="cypherxGroup_image">
                    <img src="https://i.postimg.cc/bJc1qTGB/Bo6.png" alt="Black Ops 6 Character">
                </div>
                <div class="cypherxGroup_footer">
                    <h3 class="cypherxGroup_title">Black Ops 6</h3>
                    <div class="priceFrom">
                        Starting from
                        <span class="price">$3.99</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- THE FN SECTION -->
        <div class="cypherxGroup">
            <a href="/fortnite">
                <div class="cypherxGroup_image">
                    <img src="https://i.postimg.cc/65vwvfT0/FN.png" alt="Fortnite Character">
                </div>
                <div class="cypherxGroup_footer">
                    <h3 class="cypherxGroup_title">Fortnite</h3>
                    <div class="priceFrom">
                        Starting from
                        <span class="price">$9.99</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- THE HWID SECTION -->
        <div class="cypherxGroup">
            <a href="/hwid-spoofers">
                <div class="cypherxGroup_image">
                    <img src="https://i.postimg.cc/ydjx2X09/HWID.png" alt="HWID Spoofers">
                </div>
                <div class="cypherxGroup_footer">
                    <h3 class="cypherxGroup_title">HWID Spoofers</h3>
                    <div class="priceFrom">
                        Starting from
                        <span class="price">$49.99</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- VALORANT SECTION -->
        <div class="cypherxGroup">
            <a href="/valorant">
                <div class="cypherxGroup_image">
                    <img src="https://i.postimg.cc/9X1wkVBS/VAL.png" alt="Valorant Character">
                </div>
                <div class="cypherxGroup_footer">
                    <h3 class="cypherxGroup_title">Valorant</h3>
                    <div class="priceFrom">
                        Starting from
                        <span class="price">$39.99</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- OTHER PRODUCTS -->
        <div class="cypherxGroup">
            <a href="/other">
                <div class="cypherxGroup_image">
                    <img src="https://i.postimg.cc/rmkRBw36/MRE.png" alt="Other Games">
                </div>
                <div class="cypherxGroup_footer">
                    <h3 class="cypherxGroup_title">Other</h3>
                    <div class="priceFrom">
                        Starting from
                        <span class="price">$9.99</span>
                    </div>
                </div>
            </a>
        </div>
    </div>
</body>
</html>