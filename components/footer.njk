<style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        .footer {
            background: transparent;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            padding: 48px 0;
            margin-top: auto;
            position: relative;
            overflow: hidden;
        }

        .footer-glow {
            position: absolute;
            z-index: 0;
            bottom: -200px;
            left: 50%;
            transform: translateX(-50%);
            width: 600px;
            height: 400px;
            pointer-events: none;
        }

        .footer-glow svg {
            width: 100%;
            height: 100%;
        }

        .footer-container {
            max-width: 1590px;
            margin: 0 auto;
            padding: 0 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 32px;
            position: relative;
            z-index: 1;
        }

        .footer-left {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .footer-logo {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            transition: transform 0.2s ease;
        }

        .footer-logo:hover {
            transform: translateX(2px);
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-icon img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .logo-text {
            color: #fff;
            font-weight: 600;
            font-size: 21px;
            letter-spacing: -0.02em;
        }

        .footer-copyright {
            color: #777;
            font-size: 13px;
            line-height: 1.6;
            max-width: 500px;
        }

        .footer-copyright a {
            color: #999;
            text-decoration: none;
            transition: all 0.2s ease;
            border-bottom: 1px solid transparent;
        }

        .footer-copyright a:hover {
            color: #fff;
            border-bottom-color: #fff;
        }

        .footer-right {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .footer-links {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .footer-link {
            color: #888;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
            position: relative;
            padding: 4px 0;
        }

        .footer-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 1px;
            background: #fff;
            transition: width 0.3s ease;
        }

        .footer-link:hover {
            color: #fff;
        }

        .footer-link:hover::after {
            width: 100%;
        }

        .social-links {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-left: 12px;
            border-left: 1px solid rgba(255, 255, 255, 0.1);
        }

        .social-icon {
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.05);
            color: #888;
            text-decoration: none;
            font-size: 18px;
            transition: all 0.3s ease;
            border: 1px solid transparent;
        }

        .social-icon:hover {
            background: rgba(88, 101, 242, 0.15);
            color: #5865F2;
            border-color: rgba(88, 101, 242, 0.3);
            transform: translateY(-2px);
        }

        /* Responsive Design */
        @media (max-width: 968px) {
            .footer-container {
                flex-direction: column;
                align-items: flex-start;
                gap: 32px;
            }

            .footer-left {
                width: 100%;
            }

            .footer-right {
                width: 100%;
                flex-direction: column;
                align-items: flex-start;
                gap: 20px;
            }

            .footer-links {
                gap: 20px;
            }

            .social-links {
                border-left: none;
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                padding-left: 0;
                padding-top: 12px;
            }
        }

        @media (max-width: 580px) {
            .footer {
                padding: 36px 0;
            }

            .footer-container {
                padding: 0 20px;
                gap: 24px;
            }

            .footer-logo {
                gap: 8px;
            }

            .logo-text {
                font-size: 19px;
            }

            .footer-copyright {
                font-size: 12px;
            }

            .footer-links {
                flex-wrap: wrap;
                gap: 16px;
            }

            .footer-link {
                font-size: 13px;
            }

            .social-icon {
                width: 36px;
                height: 36px;
                font-size: 16px;
            }
        }


    </style>
</head>
<body>

    <footer class="footer">
        <div class="footer-glow">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400">
                <defs>
                    <radialGradient id="footerGlow" cx="50%" cy="50%" r="50%" fx="50%" fy="50%">
                        <stop offset="0%" stop-color="#8e08ff" stop-opacity="0.15" />
                        <stop offset="50%" stop-color="#8e08ff" stop-opacity="0.08" />
                        <stop offset="100%" stop-color="#8e08ff" stop-opacity="0" />
                    </radialGradient>
                    <radialGradient id="footerGridMask" cx="50%" cy="50%" r="50%" fx="50%" fy="50%">
                        <stop offset="0%" stop-color="white" stop-opacity="0.5" />
                        <stop offset="40%" stop-color="white" stop-opacity="0.25" />
                        <stop offset="70%" stop-color="white" stop-opacity="0.1" />
                        <stop offset="100%" stop-color="white" stop-opacity="0" />
                    </radialGradient>
                    <filter id="footerBlur" x="-50%" y="-50%" width="200%" height="200%">
                        <feGaussianBlur in="SourceGraphic" stdDeviation="30" />
                    </filter>
                    <pattern id="footerGrid" width="25" height="25" patternUnits="userSpaceOnUse">
                        <path d="M 25 0 L 0 0 0 25" fill="none" stroke="rgba(153, 0, 255, 0.2)" stroke-width="0.8"/>
                    </pattern>
                    <mask id="footerGlowMask">
                        <rect width="100%" height="100%" fill="url(#footerGridMask)" />
                    </mask>
                </defs>
                <ellipse cx="300" cy="200" rx="200" ry="150" fill="url(#footerGlow)" filter="url(#footerBlur)" />
                <rect width="100%" height="100%" fill="url(#footerGrid)" mask="url(#footerGlowMask)" />
            </svg>
        </div>

        <div class="footer-container">
            <div class="footer-left">
                <a href="/" class="footer-logo" aria-label="VisionX Home">
                    <div class="logo-icon">
                        <img src="{{ shop.image_url }}">
                    </div>
                    <span class="logo-text">{{ shop.name }}</span>
                </a>
                <div class="footer-copyright">
                    Copyright © {{ shop.name }} 2026, All Rights Reserved<br>
                    Developed by <a href="https://discord.gg/gfxdesigns" target="_blank" rel="noopener noreferrer">Panther Designs</a>
                </div>
            </div>
            
            <div class="footer-right">
                <nav class="footer-links" aria-label="Footer Navigation">
                    <a href="/terms" class="footer-link">Terms of Service</a>
                    <a href="/privacy" class="footer-link">Privacy Policy</a>
                    <a href="/feedback" class="footer-link">Feedback</a>
                </nav>
                
                <div class="social-links">
                    <a href="{{ shop.discord_url }}" 
                       class="social-icon" 
                       target="_blank" 
                       rel="noopener noreferrer"
                       aria-label="Join our Discord">
                        <i class="fab fa-discord"></i>
                    </a>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>