<a
  href="{{ ('/product/' + product.path) | shopUrl }}"
  class="status-card"
>
  <div class="status-left">
    <svg
      class="status-icon"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      style="color: {{ product.status_color }}"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="m9 12 2 2 4-4"></path>
    </svg>

    <div class="status-text">
      <h3>{{ product.name }}</h3>
    </div>
  </div>

  <span
    class="status-label"
    style="color: {{ product.status_color }}"
  >
    {{ product.status_text }}
  </span>
</a>


<style>
  .status-card {
  background: linear-gradient(180deg, #161616, #191919);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 14px;
  padding: 20px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: border 0.3s ease, box-shadow 0.3s ease;
}

.status-card:hover {
  border: 1px solid {{ product.status_color }};
  box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.15);
}

.status-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.status-icon {
  width: 22px;
  height: 22px;
  color: #22c55e;
  flex-shrink: 0;
}

.status-text h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
  color: #ffffff;
}

.status-text p {
  margin: 2px 0 0;
  font-size: 13px;
  color: #8b949e;
}

.status-label {
  font-weight: 600;
  font-size: 14px;
  color: #22c55e;
}
</style>