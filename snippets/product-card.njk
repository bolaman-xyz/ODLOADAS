<a class="sa-card text-decoration-none" href="{{ 'javascript:void(0);' if product.type == 'group' else ( ('/product/' + product.path) | shopUrl ) }}"
  data-bs-toggle="{{ 'modal' if product.type == 'group' else '' }}"
  data-bs-target="{{ '#group-modal-' ~ product.id if product.type == 'group' else '' }}">
  <div class="sa-card__image-wrap">
    {% if product.image_urls|length > 0 %}
      <img src="{{ product.image_urls[0] }}" class="sa-card__image" loading="lazy" />
    {% elif product.image_url %}
      <img src="{{ product.image_url }}" class="sa-card__image" loading="lazy" />
    {% else %}
      <div class="sa-card__placeholder">
        <i class="fa-solid fa-image"></i>
      </div>
    {% endif %}
  </div>

  <div class="sa-card__body">
    <h3 class="sa-card__title">{{ product.name }}</h3>
    <div class="sa-card__footer">
      <button class="sa-card__btn" type="button">
        <i class="fa-solid fa-cart-shopping"></i> Buy Now
      </button>
      <div class="sa-card__price-block">
        <span class="sa-card__price-label">Starting At</span>
        <span class="sa-card__price">
          {% if product.min_price %}
            <span class="sa-card__price-currency">{{ product.currency }}</span>
            <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
              {{ formatPrice(product.min_price, product.currency) }}
            </span>
          {% else %}
            <span>—</span>
          {% endif %}
        </span>
      </div>
    </div>
  </div>
</a>
